## Current conditions page. Uses shared head/body/foot includes.
#errorCatcher Echo
#def lbl($key)
<span class="i18n" data-i18n="$key">$gettext($key)</span>#slurp
#end def
#def tf($v)
#return $str($v).strip().lower() not in ('false','0','no','off','')
#end def
#def vrow($key, $value, $cls='')
        <div class="line$cls"><div class="lleft">$lbl($key)</div><div class="lright">$value</div></div>
#end def
## Current value, then today's high/low stacked to its right with the time of
## each. $hi/$lo/$hit/$lot are pre-formatted (computed at the call site).
#def vrowhl($key, $value, $hi, $hit, $lo, $lot, $cls='', $hi_only=False)
        <div class="line vrowhl$cls"><div class="lleft">$lbl($key)</div><div class="lright"><span class="vh-now">$value</span><span class="vh-range"><span>&#9650; $hi<span class="vh-at">at</span>$hit</span>#if not $hi_only#<span>&#9660; $lo<span class="vh-at">at</span>$lot</span>#end if#</span></div></div>
#end def
#def hlrow($key, $stat, $hi_only=False)
        <div class="line twocol"><div class="lleft">$lbl($key)</div><div class="lright"><span>&#9650; $stat.max.format()<span class="hl-at">at</span><span class="hl-time">$stat.maxtime</span></span>#if not $hi_only#<span>&#9660; $stat.min.format()<span class="hl-at">at</span><span class="hl-time">$stat.mintime</span></span>#end if#</div></div>
#end def
